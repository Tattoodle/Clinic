# Rathmines Doctors Clinic — /dev staging area
# Keep search engines out of the staging copy.
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>

# SPA routing: serve real files, otherwise fall back to the app's index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /dev/
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule ^ index.html [L]
</IfModule>
